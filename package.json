{
  "name": "telemachus",
  "version": "0.1.0",
  "description": "Your Qwenodyssey coding agent, in the cloud, on Telegram — a single enhanced agent that runs in isolated Daytona sandboxes and is driven from a Telegram chat.",
  "license": "MIT",
  "type": "commonjs",
  "bin": {
    "telemachus": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "telegram-bot",
    "ai-agent",
    "coding-agent",
    "daytona",
    "sandbox",
    "llm",
    "nvidia-nim",
    "openrouter",
    "qwenodyssey"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.6.3"
  }
}
