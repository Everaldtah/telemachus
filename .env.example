# ── Telemachus configuration (copy to .env; NEVER commit your real .env) ──

# Telegram bot token from @BotFather (REQUIRED). Create a bot, then /token.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Comma-separated Telegram chat IDs allowed to use the bot (REQUIRED).
# Send your bot a message and check https://api.telegram.org/bot<token>/getUpdates
# to find your numeric chat id. Anyone not in this list is ignored.
TELEGRAM_ALLOWED_CHAT_IDS=5836707779

# Daytona sandbox API key (REQUIRED for cloud execution). https://app.daytona.io → API keys.
DAYTONA_API_KEY=dtn_your_key
DAYTONA_API_URL=https://app.daytona.io/api
# Optional: snapshot/image + region for new sandboxes.
DAYTONA_SNAPSHOT=
DAYTONA_TARGET=

# Storage:
# - DAYTONA_DISK_GB: sandbox scratch disk in GB (0 = Daytona default ~3GB). Quota-bound.
DAYTONA_DISK_GB=0
# - DAYTONA_VOLUME: name of a Daytona Volume (S3-backed, effectively unlimited / 1TB+)
#   mounted into every sandbox for large PERSISTENT storage. Created automatically on
#   first use. Leave blank to disable. Uses your existing Daytona key — no extra creds.
DAYTONA_VOLUME=telemachus-data
DAYTONA_VOLUME_MOUNT=/data

# Frontier model providers — set at least one.
NVIDIA_API_KEY=nvapi-your_key
OPENROUTER_API_KEY=sk-or-v1-your_key

# Default model the agent starts on (switchable in-chat via /model).
# Form: "nvidia:<model>" or "openrouter:<model>".
# NOTE: NVIDIA NIM (integrate.api.nvidia.com) is NOT reachable from Daytona's EU
# region (egress resets the connection) — use openrouter:* when running in Daytona.
TELEMACHUS_MODEL=openrouter:moonshotai/kimi-k2.7-code

# Agent limits.
TELEMACHUS_MAX_STEPS=12
TELEMACHUS_EXEC_TIMEOUT_S=180

# Swarm dashboard website (Vercel) — base URL of the telemachus-dashboard deployment.
# When set, /swarm replies with a per-session link to watch each subagent's terminal
# live. Leave blank to run swarms without the web view.
DASHBOARD_URL=https://telemachus-dashboard.vercel.app

# Internet access for the sandboxed agent. The Daytona EU sandbox resets direct
# egress to most hosts, so the agent's web_fetch tool routes through a Vercel proxy
# (full internet egress, reachable from the sandbox). Defaults to DASHBOARD_URL/api/fetch;
# set WEB_PROXY_URL to override (or "" to disable web_fetch). Screenshot mode renders
# pages to PNG via <proxy host>/api/shot.
WEB_PROXY_URL=

# Vision model (OpenRouter, multimodal) used to analyze web_fetch screenshots.
VISION_MODEL=google/gemini-2.5-flash

# Moltbook (social network for AI agents). The agent's moltbook tool routes through a
# Vercel proxy that injects the API key SERVER-SIDE (Moltbook requires the key only ever
# go to www.moltbook.com), so the sandbox never sees the key. Defaults to
# DASHBOARD_URL/api/moltbook; set MOLTBOOK_PROXY_URL to override (or "" to disable).
MOLTBOOK_PROXY_URL=
# The actual key lives ONLY in the Vercel project env as MOLTBOOK_API_KEY — do NOT put it
# here or inject it into the sandbox. (Kept in the real .env only as a backup record.)
