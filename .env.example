# ── Telemachus configuration (copy to .env; NEVER commit your real .env) ──

# Telegram bot token from @BotFather (REQUIRED). Create a bot, then /token.
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token

# Comma-separated Telegram chat IDs allowed to use the bot (REQUIRED).
# Send your bot a message and check https://api.telegram.org/bot<token>/getUpdates
# to find your numeric chat id. Anyone not in this list is ignored.
TELEGRAM_ALLOWED_CHAT_IDS=5836707779

# Daytona sandbox API key (REQUIRED for cloud execution). https://app.daytona.io → API keys.
DAYTONA_API_KEY=dtn_your_key
DAYTONA_API_URL=https://app.daytona.io/api
# Optional: snapshot/image + region for new sandboxes.
DAYTONA_SNAPSHOT=
DAYTONA_TARGET=

# Frontier model providers — set at least one.
NVIDIA_API_KEY=nvapi-your_key
OPENROUTER_API_KEY=sk-or-v1-your_key

# Default model the agent starts on (switchable in-chat via /model).
# Form: "nvidia:<model>" or "openrouter:<model>".
TELEMACHUS_MODEL=nvidia:moonshotai/kimi-k2.6

# Agent limits.
TELEMACHUS_MAX_STEPS=12
TELEMACHUS_EXEC_TIMEOUT_S=180
